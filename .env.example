# 端口（组合部署规范 8767，避开 vortex_data 的 8765）
VORTEX_BACKTEST_PUBLIC_PORT=8767
VORTEX_BACKTEST_PORT=8767

# 对外暴露地址：默认只绑宿主机回环（仅本机可访问）。
# 要对外暴露：改成 0.0.0.0，并先实现+设置 token（见 design/03 阶段6）。
VORTEX_BACKTEST_BIND_ADDR=127.0.0.1
VORTEX_BACKTEST_TOKEN=

# 宿主机挂载路径（单仓开发用）。容器内路径由 docker-compose environment: 固定（ADR-002）。
# 组合部署时由 vortex_common/deploy/ named volume 覆盖，无需填。
# 数据工作区（只读，来自 vortex_data）
VORTEX_WORKSPACE_MOUNT=../vortex_data/workspace
# 服务状态目录（账户/订单/作业/报告）
VORTEX_STATE_MOUNT=./state

TZ=Asia/Shanghai
