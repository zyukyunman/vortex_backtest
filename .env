# 端口
VORTEX_BACKTEST_PUBLIC_PORT=8765
VORTEX_BACKTEST_PORT=8765

# 对外暴露地址：默认只绑宿主机回环（仅本机可访问）。
# 要对外暴露：改成 0.0.0.0，并先实现+设置 token（见 design/03 阶段6）。
VORTEX_BACKTEST_BIND_ADDR=127.0.0.1
VORTEX_BACKTEST_TOKEN=

# 数据：来自 vortex_data 的导出目录（建议只读）。整合部署时改为共享卷。
VORTEX_BACKTEST_WORKSPACE=../vortex_data/workspace
# 账户/订单/作业/报告状态目录
VORTEX_BACKTEST_STATE=./state

TZ=Asia/Shanghai
